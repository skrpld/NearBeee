[
  {
    "create": "messages",
    "validator": {
      "$jsonSchema": {
        "bsonType": "object",
        "required": [
          "topic_id",
          "user_id",
          "content",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "topic_id": {
            "bsonType": "binData"
          },
          "user_id": {
            "bsonType": "binData"
          },
          "content": {
            "bsonType": "string",
            "minLength": 1,
            "maxLength": 4096
          },
          "created_at": {
            "bsonType": "date"
          },
          "updated_at": {
            "bsonType": "date"
          }
        }
      }
    }
  },
  {
    "createIndexes": "messages",
    "indexes": [
      {
        "key": {
          "topic_id": 1,
          "created_at": -1
        },
        "name": "idx_topic_messages_chrono",
        "background": true
      },
      {
        "key": {
          "user_id": 1
        },
        "name": "idx_user_id",
        "background": true
      }
    ]
  }
]